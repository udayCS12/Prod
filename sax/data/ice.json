{question:"In electronic governor droop is ____________ %",options:["0.8–1%","3%","1%","less than 1%"],answer:"0.8–1%",subject:"Ship Maintenance"},
{question:"DA load bank trials at 100% load is to be conducted for",options:["02 Hrs","30 Min","04 Hrs","01 Hrs"],answer:"02 Hrs",subject:"Ship Maintenance"},
{question:"SFC stands for",options:["Standard fuel consumption","Specific fuel consumption","Special fuel consumption","System fuel consumption"],answer:"Specific fuel consumption",subject:"Ship Maintenance"},
{question:"Oil film is formed in ____________ type of lubrication",options:["Hydrodynamic lubrication","Hydrostatic lubrication","Solid film lubrication","Elastohydrodynamic lubrication"],answer:"Hydrodynamic lubrication",subject:"Ship Maintenance"},
{question:"The non operational period of machinery is called",options:["Down Time","Spare Time","Shock Time","Lead Time"],answer:"Down Time",subject:"Machinery Maintenance"},
{question:"_________ can avoid failure and extend life of machine",options:["Modification","Exploitation","Maintenance","None of these"],answer:"Maintenance",subject:"Machinery Maintenance"},
{question:"Safety device checks are carried out by DTTT staff",options:["Quarterly","Monthly","Yearly","Six Monthly"],answer:"Six Monthly",subject:"Machinery Maintenance"},
{question:"_________ type of fuel pump is fitted in Mariner OBM",options:["Diaphragm","Plunger","Lift","Blower"],answer:"Diaphragm",subject:"Machinery Maintenance"},
{question:"_________ of engine is most common cause of vibration",options:["Mounting","Injector firing","Gear meshing","Unbalancing"],answer:"Unbalancing",subject:"Machinery Maintenance"},
{question:"The synthetic chemical compound added in lubricants is called",options:["Detergent","Colours","Grease","Additives"],answer:"Additives",subject:"Machinery Maintenance"},
{question:"The sulphuric acid results in excessive corrosion of",options:["Liner","Piston","Crankshaft","Connecting Rod"],answer:"Piston",subject:"Machinery Maintenance"},
