{question:"Main engines can be exploited at 100% load for ______ % of total running hrs",options:["10%","50%","33%","100%"],answer:"10%",subject:"Main Propulsion System"},
{question:"During refit Section who is responsible for accounting of machinery spares",options:["Dept Regulator","Store In-charge","Section In-charge","Engineer Officer"],answer:"Section In-charge",subject:"Main Propulsion System"},
{question:"DEHMI stands for",options:["Diesel Engine Health Monitoring & Inspection","Diesel Engine Health Monthly Inspection","Diesel Engine Health Management & Inspection","Diesel Engine Health Multiple Inspection"],answer:"Diesel Engine Health Monitoring & Inspection",subject:"Main Propulsion System"},
{question:"STC in Pielstick engine stands for",options:["Step Time Control","Speed Turbo Charging","Single Timing Control","Sequential Turbo charging"],answer:"Sequential Turbo charging",subject:"Main Propulsion System"},
{question:"DA load trials must be conducted",options:["Post replacement of FIP","Post replacement of cylinder head","Post tuning of Governor","Post replacement of injectors"],answer:"Post replacement of FIP",subject:"Main Propulsion System"},
